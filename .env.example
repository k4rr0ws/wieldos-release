# WieldOS — environment configuration
#
# Configuration is managed in the app, not in this file:
#   - Global app config (Anthropic key/model, scheduler, app base URL) lives
#     under Settings (stored in SQLite).
#   - External integrations (Twitter, Tavily, EVM, Notion, Telegram, webhook)
#     are configured as provider Instances on the Instances page.
#
# This file holds only:
#   1. Bootstrap values that MUST exist before the database is opened.
#   2. (Optional) a one-time seed: on first boot, any values present below are
#      imported once — Settings values into the database, integration values
#      into provider Instances — then the app reads from the database only.
#      Editing them here afterwards has no effect; change them in the UI.
#
# A fresh install needs nothing here except (optionally) ANTHROPIC_API_KEY to
# avoid a trip to the Settings page — everything else can be set in the UI.

# ============================================================================
# Bootstrap — process/storage config. NOT managed in the database.
# ============================================================================
# SQLite database file (default: ./data/dashboard.db). The settings table lives
# inside this file, so its location can't itself be a setting.
# DATABASE_PATH=./data/dashboard.db
# Uploaded agent avatars directory (default: ./data/uploads/avatars).
# AVATAR_DIR=./data/uploads/avatars
# HTTP bind (set by Docker/systemd in production).
# HOST=0.0.0.0
# PORT=3000

# ============================================================================
# Optional first-boot seed (A) — global app settings, imported into the
# database once, then ignored. Equivalent to the Settings page in the UI.
# ============================================================================

# --- Core AI ----------------------------------------------------------------
# Anthropic API key. Required for any agent feature (set here or in Settings).
# ANTHROPIC_API_KEY=sk-ant-...
# Model (default: claude-sonnet-4-6). Also drives cost estimates.
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Per-request timeout in ms (default: 120000, floored at 10000).
# AI_REQUEST_TIMEOUT_MS=120000

# --- Scheduler --------------------------------------------------------------
# Enable the background scheduler (1/true/yes/on). Off by default. Starting or
# stopping the loop takes effect on the next restart.
# SCHEDULER_ENABLED=0
# Tick interval in minutes (default: 15).
# SCHEDULER_INTERVAL_MINUTES=15

# --- General ----------------------------------------------------------------
# Base URL used to build absolute links in notifications.
# APP_BASE_URL=https://wieldos.example.com
# Persist raw provider payloads alongside each record (debug aid; off by default).
# RECORDS_KEEP_RAW=0

# ============================================================================
# Optional first-boot seed (B) — external integrations. On first boot these are
# folded ONCE into provider Instances (Instances page), then read from the
# database only. Manage them in the UI thereafter (add/edit/remove instances).
# ============================================================================

# --- X / Twitter (→ a 'twitter' instance) -----------------------------------
# twitterapi.io API key — enables twitter_read and X collectors.
# TWITTERAPI_API_KEY=...
# DANGER: X login cookies enable agents to act as a REAL account. Required (with
# the proxy) for twitter_action. All such actions are staged for approval first.
# TWITTER_LOGIN_COOKIES=...
# Residential proxy required by twitterapi.io write endpoints (host:port or URL).
# TWITTER_PROXY=http://user:pass@host:port

# --- Tavily (→ a 'tavily' instance; gates web_search) -----------------------
# TAVILY_API_KEY=tvly-...

# --- EVM (→ an 'evm' instance; gates chain_read) ----------------------------
# EVM_RPC_URL=https://eth-mainnet.example/v3/your-key

# --- Telegram notifications (→ a 'telegram' instance) -----------------------
# TELEGRAM_BOT_TOKEN=123456:ABC-...
# TELEGRAM_CHAT_ID=123456789

# --- Webhook notifications (→ a 'webhook' instance) -------------------------
# Receives a JSON POST { title, body, url }.
# NOTIFY_WEBHOOK_URL=https://example.com/hooks/wieldos

# --- Notion export (→ a 'notion' instance) ----------------------------------
# Integration secret, plus exactly one destination below.
# NOTION_TOKEN=secret_...
# NOTION_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_TITLE_PROPERTY=Name
