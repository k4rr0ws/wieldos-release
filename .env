# WieldOS environment — edit before starting the container.

# Public-facing URL of this instance. Required in production for CSRF protection.
ORIGIN=http://localhost:3000

# Host interface Docker binds to (default: all interfaces).
# Set to 127.0.0.1 to restrict access to localhost only.
# BIND_HOST=0.0.0.0

# Host port Docker binds to (default: 3000).
# HOST_PORT=3000
